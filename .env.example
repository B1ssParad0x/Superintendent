# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-audience
AUTH0_CLIENT_ID=your-spa-client-id

# Database
MONGO_URI=mongodb://mongo:27017

# AI & Voice
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SEC=20
ELEVEN_API_KEY=
ELEVEN_VOICE_ID=

# Solana (base64 keypair JSON for devnet)
SOLANA_KEYPAIR_JSON=
SOLANA_RPC=https://api.devnet.solana.com

# Edge & Security
EDGE_API_KEY=your-shared-edge-secret
# Optional: JSON map of node_id -> base64 Ed25519 pubkey for signature verification
# EDGE_PUBKEYS={"pi-001":"base64pubkey..."}

# URLs
HOST_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Optional
OPENWEATHER_KEY=
INGEST_LAT=40.7128
INGEST_LON=-74.006
INGEST_INTERVAL_SEC=60
MAPBOX_TOKEN=
